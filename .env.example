# Frontend (exposed to the browser — Vite requires the VITE_ prefix)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend only (Vercel serverless functions in /api — never prefix with VITE_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM API keys (backend only — call these from /api routes, never from the frontend)
ANTHROPIC_API_KEY=
GROK_API_KEY=
