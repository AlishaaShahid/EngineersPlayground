# Frontend (exposed to the browser — Next.js requires the NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend only (Next.js Route Handlers in app/api — never prefix with NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM API keys (backend only — call these from app/api routes, never from the frontend)
ANTHROPIC_API_KEY=
GROK_API_KEY=
